<!-- ============================================ -->
<!--               Navigation Bar                 -->
<!-- ============================================ -->

<%- include('partials/shared', { home, navigationBarColor, userId, email, fullName, role, titleColor}) %>

<!-- ============================================ -->
<!--              Display Inventory               -->
<!-- ============================================ -->

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>All Inventory</h2>
        <a href="/api/add-inventories-34890645?userId=<%= userId %>&&email=<%=email%>&&fullName=<%=fullName%>&&role=<%=role%>" class="btn btn-success">+ Add New Inventory</a>
    </div>

    <% if (inventories.length===0) { %>
        <div class="alert alert-info">
            No Ingredient found. <a href="/api/add-inventories-34890645?userId=<%= userId %>&&email=<%=email%>&&fullName=<%=fullName%>&&role=<%=role%>">Add the first ingredient</a>
        </div>
        <% } else { %>
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>Ingredient ID</th>
                            <th>Ingredient Name</th>
                            <th>Quantity</th>
                            <th>Stock</th>
                            <th>Unit</th>
                            <th>Category</th>
                            <th>Purchase Date</th>
                            <th>Expiration Date</th>
                            <th>Location</th>
                            <th>Cost</th>
                            <th>Created Date</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% inventories.forEach(inventory => { %>
                            <tr>
                                <td>
                                    <%= inventory.inventoryId %>
                                </td>
                                <td>
                                    <%= inventory.ingredientName %>
                                </td>
                                <td>
                                    <%= inventory.quantity %>
                                </td>
                                <td>
                                    <%= inventory.stock %>
                                </td>
                                <td>
                                    <%= inventory.unit%>
                                </td>
                                <td>
                                    <%= inventory.category %>
                                </td>
                                <td>
                                    <%= inventory.purchaseDate.toISOString().split('T')[0] %>  <%# reference: https://stackoverflow.com/questions/47066555/remove-time-after-converting-date-toisostring%>
                                </td>
                                <td>
                                    <%= inventory.expirationDate.toISOString().split('T')[0] %>
                                </td>
                                <td>
                                    <%= inventory.location %>
                                </td>
                                <td>
                                    <%= inventory.cost %>
                                </td>
                                <td>
                                    <%= inventory.createdDate.toISOString().split('T')[0] %>
                                </td>
                                <td>
                                    <a href="/inventories/<%= inventory._id %>/edit?userId=<%= userId %>&&email=<%=email%>&&fullName=<%=fullName%>&&role=<%=role%>" class="btn btn-sm btn-warning">Edit</a>
                                    <form method="POST" action="/inventories/<%= inventory._id %>/delete" style="display: inline;">
                                        <input type="hidden" name="userId" value="<%= userId %>">
                                        <input type="hidden" name="fullName" value="<%= fullName %>">
                                        <input type="hidden" name="email" value="<%= email %>">
                                        <input type="hidden" name="role" value="<%= role %>">
                                        <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Are you sure?')">Delete</button>
                                    </form>
                                </td>
                            </tr>
                            <% }); %>
                    </tbody>
                </table>
            </div>
            <% } %>

<!-- ============================================ -->
<!--               Total Calculation              -->
<!-- ============================================ -->

            <div style="margin-top: 5px;">
            <div class="total my-4 text-center" style="background-color: #28a745; color: white; font-weight: bold;">     
                <h2>Total Inventory Value:</h2>
                <p>$<%= totalValue.toFixed(2) %></p>
                <%#reference:https://www.w3schools.com/jsref/jsref_tofixed.asp%>
            </div>
            </div>

<!-- ============================================ -->
<!--               Expiring Date                  -->
<!-- ============================================ -->

            <div style="margin-top: 100px;">
            <h2 class = "text-center"style="background-color: #a72828; color: white; font-weight: bold; padding: 10px">🚨Items Expiring Within 3 Days</h2>
            <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead >
                    <tr>
                        <th style="background-color: #dc5959;">Ingredient</th>
                        <th style="background-color: #dc5959;">Quantity</th>
                        <th style="background-color: #dc5959;"> Location</th>
                        <th style="background-color: #dc5959;">Expiration Date</th>
                        <th style="background-color: #dc5959;">Days Left</th>
                    </tr>
                </thead>
                <tbody>
                <% let expiring = false; %>
                <% for (let i=0; i < inventories.length; i++){
                    const currentDate = new Date();
                    const expirationDate = new Date(inventories[i].expirationDate);
                    const dayDifferent = expirationDate - currentDate;
                    const dayLeft = Math.ceil(dayDifferent / (1000 * 60 * 60 * 24))

                    if(dayLeft <=3){ 
                        expiring = true;%>
                        <tr class = "<%= dayLeft <= 0? 'table-danger' : 'table-warning' %>">
                            <td><%= inventories[i].ingredientName%></td>
                            <td><%= inventories[i].quantity%></td>
                            <td><%= inventories[i].location%></td>
                            <td><%= inventories[i].expirationDate.toISOString().split('T')[0]%></td>
                            <td>
                                <% if(dayLeft== 0 ){ %>
                                    <p>Expired</p>
                                <%} else if(dayLeft <=3){ %>
                                    <p><%= dayLeft%></p>
                                <% }%>
                            </td>
                        </tr>
                    <%} 
                }%>
                </tbody>
            </table>
            <% if(!expiring) { %>
                <p class="text-center" style="color: red; font-weight: bold;">No ingredient will Expired in 3 days</p>
                <%} %>
        </div> 
        </div>

<!-- ============================================ -->
<!--                 Stock Alert                  -->
<!-- ============================================ -->

        <div style="margin-top: 100px;">
            <h2 class="text-center" style="background-color: #dcd859; color: white; font-weight: bold; padding: 10px;">⚠️Low Stock Item</h2>
        </div>
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th style="background-color: #eae794;">Ingredient</th>
                        <th style="background-color: #eae794;">Current Stock</th>
                        <th style="background-color: #eae794;"> Location</th>
                        <th style="background-color: #eae794;">Cost per Unit</th>
                        <th style="background-color: #eae794;">Suggested order</th>
                    </tr>
                </thead>
                <tbody>
                    <% let lowStock = false; %>
                    <% for (let i=0; i < inventories.length; i++){
                        if(inventories[i].quantity < inventories[i].stock){
                            let suggestion = inventories[i].stock - inventories[i].quantity;
                            lowStock = true;
                    %>
                            <tr>
                                <td><%= inventories[i].ingredientName%></td>
                                <td><%= inventories[i].quantity%></td>
                                <td><%= inventories[i].location%></td>
                                <td><%= inventories[i].cost%></td>
                                <td><%= suggestion %></td>
                            </tr>
                        <% }
                    } %>
                </tbody>
            </table>
            <% if(!lowStock){ %>
                <p class="text-center" style="color: red; font-weight: bold;">No low stock</p>
            <% } %>
        </div>

        <div>
            <input type="text" name="userId" value="<%= userId %>" hidden/>
        </div>

        <div>
            <input type="text" name="fullName" value="<%= fullName %>" hidden/>
        </div>
        
        <div>
            <input type="text" name="email" value="<%= email %>" hidden/>
        </div>

        <div>
            <input type="text" name="role" value="<%= role %>" hidden />
        </div>
    </div>      
</body>
            
<%- include('partials/footer') %>