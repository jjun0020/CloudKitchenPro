<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        Manager
    </title>
    <link href="/css/bootstrap.min.css" rel="stylesheet">
</head>

<!-- ============================================ -->
<!--                Navigation                    -->
<!-- ============================================ -->
 
<body>
    <nav class="navbar navbar-expand-lg navbar-dark" style="background-color: #5eb572;">
        <div class="container">
            <a class="navbar-brand" href="/api/manager-page-34890645?email=<%=email%>&&fullName=<%=fullName%>&&userId=<%=userId%>">
                Manager CloudKitchen Pro
            </a>
            <div class="navbar-nav">
                <a class="nav-link" href="/api/view-inventory-34890645?userId=<%= userId %>&&email=<%=email%>&&fullName=<%=fullName%>">View Inventory</a>
                <a class="nav-link" href="/api/add-inventories-34890645?userId=<%= userId %>&&email=<%=email%>&&fullName=<%=fullName%>">Add Inventory</a>
                <a href="/api/login-34890645" class="btn btn-danger">Logout</a>
            </div>
        </div>
    </nav>

<!-- ============================================ -->
<!--                Hero Section                  -->
<!-- ============================================ -->

    <div class="container text-center my-5 bg-success text-white p-5 rounded">
        <h1 class="display-4">🍳CloudKitchen Pro🍰</h1>
        <p class="lead">Enterprise Kitchen Management & Recipe Intelligence Platform</p>
        <p class="lead fw-bold">Welcome Manager <%= fullName %>!</p>
        <p class="lead fw-bold">
            <%= email %>!
        </p>
    </div>

<!-- ============================================ -->
<!--       Display Total Manger and Inventory     -->
<!-- ============================================ -->

<div class="d-flex gap-2 justify-content-center gap-4 my-4">
    <div class="col-md-3">
        <div class="ard text-center shadow-sm">
            <div class="card-body">
                <h3 class="card-title">🧑‍💼Total Mangers</h3>
                <p class="display-5 text-primary">
                    <%= countManger %>
                </p>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="ard text-center shadow-sm">
            <div class="card-body">
                <h3 class="card-title">📦Total Inventories</h3>
                <p class="display-5 text-primary">
                    <%= countInventory %>
                </p>
            </div>
        </div>
    </div>
</div>

    <div>
        <input type="text" name="userId" value="<%= userId %>" hidden />
    </div>
    <div>
        <input type="text" name="fullName" value="<%= fullName %>" hidden />
    </div>
    
    <div>
        <input type="text" name="email" value="<%= email %>" hidden  />
    </div>
    <div class="container mt-4">