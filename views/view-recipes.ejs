<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        Chef
    </title>
    <link href="/css/bootstrap.min.css" rel="stylesheet">
</head>

<!-- ============================================ -->
<!--                Navigation                    -->
<!-- ============================================ -->

<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container">
            <a class="navbar-brand"
                href="/api/chef-page-34890645?email=<%=email%>&&fullName=<%=fullName%>&&userId=<%=userId%>">
                Chef CloudKitchen Pro
            </a>
            <div class="navbar-nav">
                <a class="nav-link"
                    href="/api/view-recipes-34890645?email=<%=email%>&&fullName=<%=fullName%>&&userId=<%=userId%>">View
                    Recipe</a>
                <a class="nav-link"
                    href="/api/add-recipes-34890645?email=<%=email%>&&fullName=<%=fullName%>&&userId=<%=userId%>">Add
                    Recipe</a>
                <a class="nav-link"
                    href="/api/update-recipes-34890645?email=<%=email%>&&fullName=<%=fullName%>&&userId=<%=userId%>">Update Recipe</a>
                <a class="nav-link"
                    href="/api/delete-recipes-34890645?email=<%=email%>&&fullName=<%=fullName%>&&userId=<%=userId%>">Delete Recipe</a>
                <a class="nav-link"
                    href="/api/recipe-integration-34890645?email=<%=email%>&&fullName=<%=fullName%>&&userId=<%=userId%>">HD 1</a>

                <a href="/api/login-34890645" class="btn"
                    style="background-color:rgb(234, 40, 40); color:white;">Logout</a>
            </div>
        </div>
    </nav>
    <div class="container mt-4">

<!-- ============================================ -->
<!--                Display Recipe                -->
<!-- ============================================ -->

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>All Recipe</h2>
        <div class="d-flex gap-2">
        <a href="/api/add-recipes-34890645?email=<%=email%>&&fullName=<%=fullName%>&&userId=<%=userId%>" class="btn btn-success">+ Add New Recipe</a>
        <a href="/api/delete-recipes-34890645?email=<%=email%>&&fullName=<%=fullName%>&&userId=<%=userId%>" class="btn" style = "background-color: rgb(237, 26, 26); color: white;">- Delete Recipe</a>
    </div>
    </div>

    <% if (recipes.length===0) { %>
        <div class="alert alert-info">
            No Recipe found. <a href="/api/add-recipes-34890645?email=<%=email%>&&fullName=<%=fullName%>&&userId=<%=userId%>">Add the first recipe</a>
        </div>
        <% } else { %>
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>Recipe Id</th>
                            <th>Title</th>
                            <th>Chef</th>
                            <th>Ingredients</th>
                            <th>Instructions</th>
                            <th>Meal Type</th>
                            <th>Cuisine Type</th>
                            <th>Prep Time</th>
                            <th>Difficulty</th>
                            <th>Servings</th>
                            <th>created Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% recipes.forEach(recipe=> { %>
                            <tr>
                                <td>
                                    <%= recipe.recipeId %>
                                </td>

                                <td>
                                    <%= recipe.title %>
                                </td>

                                <td>
                                    <%= recipe.chef %>
                                </td>

                                <td>
                                    <ul>
                                        <% recipe.ingredients.forEach(item=> { %>
                                            <li>
                                                <%= item.itemQuantity %>
                                                <%= item.itemUnit %>
                                                <%= item.itemName %>
                                            </li>
                                        <% }) %>
                                    </ul>

                                </td>

                                <td>
                                    <ul>
                                        <% recipe.instructions.forEach(item => { %>
                                            <li>
                                                <%= item %>
                                            </li> 
                                        <% }) %>
                                    </ul>
                                </td>

                                <td>
                                    <%= recipe.mealType %>
                                </td>

                                <td>
                                    <%= recipe.cuisineType %>
                                </td>

                                <td>
                                    <%= recipe.prepTime %>
                                </td>

                                <td>
                                    <%= recipe.difficulty %>
                                </td>

                                <td>
                                    <%= recipe.servings %>
                                </td>

                                <td>
                                    <%= recipe.createdDate.toISOString().split('T')[0] %>
                                </td>
                            </tr>
                            <% }); %>
                    </tbody>
                </table>
            </div>
        <% } %>

        <div>
            <input type="text" name="userId" value="<%= userId %>" hidden />
        </div>
        <div>
            <input type="text" name="fullName" value="<%= fullName %>" hidden/>
        </div>
        
        <div>
            <input type="text" name="email" value="<%= email %>" hidden />
        </div>
    </body>
<%- include('partials/footer') %>