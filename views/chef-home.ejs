<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        Chef
    </title>
    <link href="/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>
<!-- ============================================ -->
<!--                Navigation                    -->
<!-- ============================================ -->

    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container">
            <a class="navbar-brand" href="/api/chef-page-34890645?email=<%=email%>&&fullName=<%=fullName%>&&userId=<%=userId%>">
                Chef CloudKitchen Pro
            </a>
            <div class="navbar-nav">
                <a class="nav-link" href="/api/view-recipes-34890645?email=<%=email%>&&fullName=<%=fullName%>&&userId=<%=userId%>">View Recipe</a>
                <a class="nav-link" href="/api/add-recipes-34890645?email=<%=email%>&&fullName=<%=fullName%>&&userId=<%=userId%>">Add Recipe</a>
                <a class="nav-link" href="/api/update-recipes-34890645?email=<%=email%>&&fullName=<%=fullName%>&&userId=<%=userId%>">Update Recipe</a>
                <a class="nav-link" href="/api/delete-recipes-34890645?email=<%=email%>&&fullName=<%=fullName%>&&userId=<%=userId%>">Delete Recipe</a>
                <a class="nav-link" href="/api/recipe-integration-34890645?email=<%=email%>&&fullName=<%=fullName%>&&userId=<%=userId%>">HD 1</a>
                <a href="/api/login-34890645" class="btn" style="background-color:rgb(234, 40, 40); color:white;">Logout</a>
            </div>
        </div>
    </nav>

<!-- ============================================ -->
<!--                Hero Section                  -->
<!-- ============================================ -->

    <div class="container text-center my-5 bg-info text-white p-5 rounded">
        <h1 class="display-4">🍳CloudKitchen Pro🍰</h1>
        <p class="lead">Enterprise Kitchen Management & Recipe Intelligence Platform</p>
        <p class="lead fw-bold">Welcome Chef <%= fullName %>!</p>
        <p class="lead fw-bold"> <%= email %>!</p>
    </div>

<!-- ============================================ -->
<!--       Display Total Chef and Recipe          -->
<!-- ============================================ -->
    
    <div class="d-flex gap-2 justify-content-center gap-4 my-4">
        <div class = "col-md-3">
            <div class = "ard text-center shadow-sm">
                <div class = "card-body">
                    <h3 class = "card-title">👩‍🍳Total Chefs</h3>
                    <p class = "display-5 text-primary"> <%= countChef %></p>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="ard text-center shadow-sm">
                <div class="card-body">
                    <h3 class="card-title">📚Total Recipes</h3>
                    <p class="display-5 text-primary">
                        <%= countRecipe %>
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="ard text-center shadow-sm">
                <div class="card-body">
                    <h3 class="card-title">📦Total Inventories</h3>
                    <p class="display-5 text-primary">
                        <%= countInventory %>
                    </p>
                </div>
            </div>
        </div>
    </div>

    <div>
        <input type="text" name="userId" value="<%= userId %>" hidden />
    </div>
    <div>
        <input type="text" name="fullName" value="<%= fullName %>" hidden/>
    </div>
    
    <div>
        <input type="text" name="email" value="<%= email %>" hidden />
    </div>

    
    <div class="container mt-4">
