<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        Chef
    </title>
    <link href="/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container">
            <a class="navbar-brand"
                href="/api/chef-page-34890645?email=<%=email%>&&fullName=<%=fullName%>&&userId=<%=userId%>">
                Chef CloudKitchen Pro
            </a>
            <div class="navbar-nav">
                <a class="nav-link"
                    href="/api/view-recipes-34890645?email=<%=email%>&&fullName=<%=fullName%>&&userId=<%=userId%>">View
                    Recipe</a>
                <a class="nav-link"
                    href="/api/add-recipes-34890645?email=<%=email%>&&fullName=<%=fullName%>&&userId=<%=userId%>">Add
                    Recipe</a>
                <a class="nav-link"
                    href="/api/update-recipes-34890645?email=<%=email%>&&fullName=<%=fullName%>&&userId=<%=userId%>">Update
                    Recipe</a>
                <a class="nav-link"
                    href="/api/delete-recipes-34890645?email=<%=email%>&&fullName=<%=fullName%>&&userId=<%=userId%>">Delete
                    Recipe</a>

                <a href="/api/login-34890645" class="btn"
                    style="background-color:rgb(234, 40, 40); color:white;">Logout</a>
            </div>
        </div>
    </nav>
    <div class="container mt-4">

<!-- ============================================ -->
<!--                  update                      -->
<!-- ============================================ -->
        <h2 class = "text-center">🍳Update Recipe✨</h2>
        <div class="card shadow-sm">
        <div class="card-body">
        <form action = "/updateRecipeByid?email=<%=email%>&&fullName=<%=fullName%>&&userId=<%=userId%>" method="POST">
            <div class = "text-center col-md-8" style="margin-left: 30vh;">
                <label>
                    Enter Recipe ID:
                    <input type="text" placeholder="Search by Id...." name="recipeId" required>
                    <button class="submit">Submit</button>
                </label>
            </div>

            </div>
            <div>
                <input type="text" name="userId" value="<%= userId %>" hidden/>
            </div>
            <div>
                <input type="text" name="fullName" value="<%= fullName %>" hidden/>
            </div>
            
            <div>
                <input type="text" name="email" value="<%= email %>" hidden/>
            </div>
        </form>

        <% if (recipes.length===0) { %>
            <div class="alert alert-info">
                No Recipe Added. <a
                    href="/api/add-recipes-34890645?email=<%=email%>&&fullName=<%=fullName%>&&userId=<%=userId%>">Add the first
                    Recipe</a>
            </div>
        <% } %>
        <% if(message) { %>
            <p style = "color: red;"><%= message %></p>
        <% } %>

       <% if(recipe) { %>
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>Recipe Id</th>
                                <th>Title</th>
                                <th>Chef</th>
                                <th>Ingredients</th>
                                <th>Instructions</th>
                                <th>Meal Type</th>
                                <th>Cuisine Type</th>
                                <th>Prep Time</th>
                                <th>Difficulty</th>
                                <th>Servings</th>
                                <th>created Date</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                                <tr>
                                    <td>
                                        <%= recipe.recipeId %>
                                    </td>

                                    <td>
                                        <%= recipe.title %>
                                    </td>

                                    <td>
                                        <%= recipe.chef %>
                                    </td>

                                    <td>
                                        <%= recipe.ingredients %>
                                    </td>


                                    <td>
                                        <%= recipe.instructions %>
                                    </td>

                                    <td>
                                        <%= recipe.mealType %>
                                    </td>

                                    <td>
                                        <%= recipe.cuisineType %>
                                    </td>

                                    <td>
                                        <%= recipe.prepTime %>
                                    </td>

                                    <td>
                                        <%= recipe.difficulty %>
                                    </td>

                                    <td>
                                        <%= recipe.servings %>
                                    </td>

                                    <td>
                                        <%= recipe.createdDate.toISOString().split('T')[0] %>
                                    </td>

                                    <td>
                                        <a href="/<%= recipe._id %>/edit?userId=<%= userId %>&&email=<%=email%>&&fullName=<%=fullName%>"
                                            class="btn btn-sm btn-warning">Edit</a>
                                    </td>
                                </tr>
                        </tbody>
                    </table>
                </div>
                <% } %>
</body>
<%- include('partials/footer') %>