<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>
<!-- ============================================ -->
<!--                Navigation                    -->
<!-- ============================================ -->

    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container">
            <a class="navbar-brand"
                href="/api/chef-page-34890645?email=<%=email%>&&fullName=<%=fullName%>&&userId=<%=userId%>">
                Chef CloudKitchen Pro
            </a>
            <div class="navbar-nav">
                <a class="nav-link" href="/api/view-recipes-34890645?email=<%=email%>&&fullName=<%=fullName%>&&userId=<%=userId%>">View Recipe</a>
                <a class="nav-link" href="/api/add-recipes-34890645?email=<%=email%>&&fullName=<%=fullName%>&&userId=<%=userId%>">Add Recipe</a>
                <a class="nav-link" href="/api/update-recipes-34890645?email=<%=email%>&&fullName=<%=fullName%>&&userId=<%=userId%>">Update Recipe</a>
                <a class="nav-link" href="/api/delete-recipes-34890645?email=<%=email%>&&fullName=<%=fullName%>&&userId=<%=userId%>">Delete Recipe</a>
                <a class="nav-link" href="/api/recipe-integration-34890645?email=<%=email%>&&fullName=<%=fullName%>&&userId=<%=userId%>">HD 1</a>
                <a href="/api/login-34890645" class="btn" style="background-color:rgb(234, 40, 40); color:white;">Logout</a>
            </div>
        </div>
    </nav>

<!-- ============================================ -->
<!--                Add Recipe                    -->
<!-- ============================================ -->

    <h2 class = "text-center">🍳 Add To CookBook </h2>
    <div class="d-flex justify-content-center align-items-center min-vh-100" >
        
        <form method="POST" action="/addRecipe" class="w-100" style="max-width: 1500px; padding-left: 70vh;">
            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label for="text" class="form-label">Title:</label>
                        <input type="text" class="form-control" name="title" required>
                    </div>
                </div>
            </div>
            
            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label for="firstName" class="form-label">Chef Name:</label>
                        <input type="text" class="form-control" name="chef" required>
                    </div>
                </div>
            </div>
        
            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label for="firstName" class="form-label">Ingredients:</label>
                        <textarea type="text" class="form-control" name="ingredients" rows="4" required></textarea>
                    </div>
                </div>
            </div>
        
            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label for="firstName" class="form-label">Instructions:</label>
                        <textarea type="text" class="form-control" name="instructions" rows="4" required> </textarea>
                    </div>
                </div>
            </div>
        
            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="form-label">Meal Type:</label>
                        <select class="form-control" name="mealType" required>
                            <option value="">Select a role</option>
                            <option value="Breakfast">Breakfast</option>
                            <option value="Lunch">Lunch</option>
                            <option value="Dinner">Dinner</option>
                            <option value="Snack">Snack</option>
                        </select>
                    </div>
                </div>
            </div>
        
            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="form-label">Cuisine Type:</label>
                        <select class="form-control" name="cuisineType" required>
                            <option value="">Select a role</option>
                            <option value="Italian">Italian</option>
                            <option value="Asian">Asian</option>
                            <option value="Mexican">Mexican</option>
                        </select>
        
                    </div>
                </div>
            </div>
        
            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label for="firstName" class="form-label">Prep Time:</label>
                        <input type="number" class="form-control" name="prepTime" min="1" max="480" required>
                    </div>
                </div>
            </div>
        
        
            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="form-label">Difficulty:</label>
                        <select class="form-control" name="difficulty" required>
                            <option value="">Select a role</option>
                            <option value="Easy">Easy</option>
                            <option value="Medium">Medium</option>
                            <option value="Hard">Hard</option>
                        </select>
                    </div>
                </div>
            </div>
        
            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label for="firstName" class="form-label">Servings:</label>
                        <input type="number" class="form-control" name="servings" min="1" max="20" required>
                    </div>
                </div>
            </div>

            <div>
                <input type="text" name="userId" value="<%= userId %>" hidden />
            </div>
            <div>
                <input type="text" name="fullName" value="<%= fullName %>" hidden />
            </div>
            
            <div>
                <input type="text" name="email" value="<%= email %>" hidden/>
            </div>

        
            <div class="mb-3">
                <button type="submit" class="btn btn-primary">Submit</button>
                <a href="" class="btn btn-secondary">Cancel</a>
            </div>
        
        </form>
    </div>
        

        <%- include('partials/footer') %>
</body>

</html>