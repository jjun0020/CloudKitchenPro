<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/all.css">
</head>

<body>
    <%- include('partials/header', { title: 'Add Recipe' }) %>

        <h2>🍳 Add To Cook Book </h2>

        <form method="POST" action="/addRecipe">
            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label for="email" class="form-label">Title:</label>
                        <input type="email" class="form-control" name="title" required>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label for="firstName" class="form-label">Chef Name:</label>
                        <input type="text" class="form-control" name="chef" required>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="form-label">Meal Type:</label>
                        <select class="form-control" name="mealType" required>
                            <option value="">Select a role</option>
                            <option value="Breakfast">Breakfast</option>
                            <option value="Lunch">Lunch</option>
                            <option value="Dinner">Dinner</option>
                            <option value="Snack">Snack</option>
                        </select>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label for="firstName" class="form-label">Prep Time:</label>
                        <input type="number" class="form-control" name="prepTime" min = "1" max = "480" required>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="form-label">Cuisine Type:</label>
                        <select class="form-control" name="cuisineType" required>
                            <option value="">Select a role</option>
                            <option value="Easy">Easy</option>
                            <option value="Medium">Medium</option>
                            <option value="Hard">Hard</option>
                        </select>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="form-label">Difficulty:</label>
                        <select class="form-control" name="difficulty required>
                            <option value="">Select a role</option>
                            <option value="Italian">Italian</option>
                            <option value="Asian">Asian</option>
                            <option value="Mexican">Mexican</option>
                        </select>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label for="firstName" class="form-label">Servings:</label>
                        <input type="number" class="form-control" name="servings" min="1" max="20" required>
                    </div>
                </div>
            </div>

            <div class="mb-3">
                <button type="submit" class="btn btn-primary">Submit</button>
                <a href="" class="btn btn-secondary">Cancel</a>
            </div>
        </form>

        <%- include('partials/footer') %>
</body>

</html>